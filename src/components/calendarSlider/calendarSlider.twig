<div class="swiper calendarSlider">
  <button class="swiper-btn prev" aria-label="Previous">
    {% include "@images/chevron-down.svg" %}
  </button>
  <ul role="list" class="swiper-wrapper infinite-scroll-swiper">
    {% for i in 1..20 %}
    <li class="swiper-slide">
      <a href="#" class="calendarSlider-day" data-date="2026-01-25">20. 1.</a>
    </li>
    {% endfor %}
    <li class="swiper-slide">
      <a href="#" class="calendarSlider-day" data-date="2026-01-22"
        >Yesterday</a
      >
    </li>

    <li class="swiper-slide is-current">
      <a href="#" class="calendarSlider-day" data-date="2026-01-23">Today</a>
    </li>

    <li class="swiper-slide">
      <a href="#" class="calendarSlider-day" data-date="2026-01-24">Tomorrow</a>
    </li>

    {% for i in 1..10 %}
    <li class="swiper-slide">
      <a href="#" class="calendarSlider-day" data-date="2026-01-25">31. 1.</a>
    </li>
    {% endfor %}
  </ul>

  <button class="swiper-btn next" aria-label="Previous">
    {% include "@images/chevron-down.svg" %}
  </button>
</div>
