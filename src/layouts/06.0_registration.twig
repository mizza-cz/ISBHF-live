{% extends "@components/base/base.twig" %} {% set title = "06.0_registration" %}
{% block main %}

<div class="bg-registration min-height-screen">
  {% include "@components/header/header-reg.twig" %}
  <main class="main" aria-label="Hlavní obsah">
    <section class="pt-lg-16 pt-10 pb-lg-20 pb-10">
      <div class="container">
        <div class="position-relative">
          <div class="text-center mb-6">
            <h1 class="h2 text-light mb-4 titleDecore">
              Create your ISBHF account
            </h1>
            <p class="text-gray-300 text-md mx-auto" style="max-width: 416px">
              Register to watch live matches, access replays, and follow
              international ball hockey events.
            </p>
          </div>
          <div class="registration">
            <div class="container-xxs">
              <div class="registration__social">
                <button
                  type="button"
                  class="registration__social-button"
                  onclick="handleAppleRegister()"
                >
                  <img
                    class="object-fit-contain"
                    src="images/ico/apple.svg"
                    width="20"
                    height="20"
                    alt="apple"
                  />
                  <span>Sign up with Apple</span>
                </button>

                <button
                  type="button"
                  class="registration__social-button"
                  onclick="handleGoogleRegister()"
                >
                  <img
                    class="object-fit-contain"
                    src="images/ico/google.svg"
                    width="20"
                    height="20"
                    alt="apple"
                  />
                  <span>Sign up with Google</span>
                </button>
              </div>
              <div class="registration__divider">or</div>
              <form
                class="registration__form"
                action="/registration"
                method="post"
                novalidate
              >
                <div class="registration__field">
                  <label for="register-first-name">Name</label>
                  <input
                    id="register-first-name"
                    name="firstName"
                    type="text"
                    placeholder="Name"
                    autocomplete="given-name"
                    required
                  />
                  <p
                    class="registration__error"
                    id="register-first-name-error"
                    hidden
                  ></p>
                </div>

                <div class="registration__field">
                  <label for="register-last-name">Surname</label>
                  <input
                    id="register-last-name"
                    name="lastName"
                    type="text"
                    placeholder="Surname"
                    autocomplete="family-name"
                    required
                  />
                  <p
                    class="registration__error"
                    id="register-last-name-error"
                    hidden
                  ></p>
                </div>

                <div class="registration__field">
                  <label for="register-email">E-mail</label>
                  <input
                    id="register-email"
                    name="email"
                    type="email"
                    placeholder="E-mail"
                    autocomplete="email"
                    inputmode="email"
                    required
                  />
                  <p
                    class="registration__error"
                    id="register-email-error"
                    hidden
                  ></p>
                </div>

                <div class="registration__field">
                  <label for="register-password">Password</label>
                  <div class="registration__password-wrap">
                    <input
                      id="register-password"
                      name="password"
                      type="password"
                      placeholder="Password"
                      autocomplete="new-password"
                      required
                    />
                    <button
                      type="button"
                      class="registration__password-toggle"
                      aria-label="Show password"
                      onclick="togglePassword('register-password', this)"
                    >
                      👁
                    </button>
                  </div>
                  <p
                    class="registration__error"
                    id="register-password-error"
                    hidden
                  ></p>
                </div>

                <div class="registration__field">
                  <label for="register-password-repeat">Repeat password</label>
                  <input
                    id="register-password-repeat"
                    name="passwordRepeat"
                    type="password"
                    placeholder="Repeat password"
                    autocomplete="new-password"
                    required
                  />
                  <p
                    class="registration__error"
                    id="register-password-repeat-error"
                    hidden
                  ></p>
                </div>

                <button type="submit" class="registration__submit">
                  Create account
                </button>
              </form>
              <div class="text-md text-center text-gray-300 mt-lg-12 mt-10">
                Already have an account?
                <a href="#" class="d-block text-accent underline">Log in</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</div>
<script>
  function togglePassword(inputId, button) {
    const input = document.getElementById(inputId);
    if (!input) return;

    const isPassword = input.type === "password";
    input.type = isPassword ? "text" : "password";
    button.setAttribute(
      "aria-label",
      isPassword ? "Hide password" : "Show password"
    );
  }

  function handleAppleRegister() {
    window.location.href = "/registration";
  }

  function handleGoogleRegister() {
    window.location.href = "/registration/google/register";
  }

  function handleAppleLogin() {
    window.location.href = "/registration/apple/login";
  }

  function handleGoogleLogin() {
    window.location.href = "/login";
  }
</script>
{% include "@components/modalPromo/modalPromo.twig"%} {% endblock %}
